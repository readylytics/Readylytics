<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <uses-permission android:name="android.permission.INTERNET" />

    <uses-permission android:name="android.permission.health.READ_SLEEP" />
    <uses-permission android:name="android.permission.health.READ_HEART_RATE" />
    <uses-permission android:name="android.permission.health.READ_HEART_RATE_VARIABILITY" />
    <uses-permission android:name="android.permission.health.READ_HEALTH_DATA_HISTORY" />
    <uses-permission android:name="android.permission.health.READ_EXERCISE" />
    <uses-permission android:name="android.permission.health.READ_STEPS" />
    <!-- For backward compatibility with Android 13 and below -->
    <uses-permission android:name="com.google.android.apps.healthdata.permission.READ_SLEEP" />
    <uses-permission android:name="com.google.android.apps.healthdata.permission.READ_HEART_RATE" />
    <uses-permission android:name="com.google.android.apps.healthdata.permission.READ_HEART_RATE_VARIABILITY" />
    <uses-permission android:name="com.google.android.apps.healthdata.permission.READ_EXERCISE" />
    <uses-permission android:name="com.google.android.apps.healthdata.permission.READ_STEPS" />

    <!-- Custom permissions for widget system security -->
    <permission
        android:name="com.gregor.lauritz.healthdashboard.WIDGET_SYNC_PERMISSION"
        android:protectionLevel="internal"
        android:label="@string/widget_sync_permission_label"
        android:description="@string/widget_sync_permission_description" />

    <!-- Required on Android 11+ so the HC package is visible to our app -->
    <queries>
        <package android:name="com.google.android.apps.healthdata" />
        <package android:name="com.google.android.gms" />
        <intent>
            <action android:name="androidx.health.ACTION_SHOW_PERMISSIONS_RATIONALE" />
        </intent>
    </queries>

    <application
        android:name=".HealthDashboardApplication"
        android:allowBackup="false"
        android:networkSecurityConfig="@xml/network_security_config"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.FitDashboard">
        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:label="@string/app_name"
            android:theme="@style/Theme.App.Starting">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />

                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
            <!-- Deep-link intent filter for widget navigation -->
            <intent-filter android:label="@string/app_name">
                <action android:name="android.intent.action.VIEW" />
                <category android:name="android.intent.category.DEFAULT" />
                <category android:name="android.intent.category.BROWSABLE" />
                <data
                    android:scheme="app"
                    android:host="metric"
                    android:pathPrefix="/" />
                <data
                    android:scheme="app"
                    android:host="dashboard" />
            </intent-filter>
        </activity>
        <activity
            android:name=".ui.onboarding.PrivacyRationaleActivity"
            android:exported="true">
            <intent-filter>
                <action android:name="androidx.health.ACTION_SHOW_PERMISSIONS_RATIONALE" />
            </intent-filter>
        </activity>

        <!-- Widget configuration activities -->
        <activity
            android:name=".widgets.config.SmallWidgetConfigActivity"
            android:exported="true"
            android:label="@string/app_name">
            <intent-filter>
                <action android:name="android.appwidget.action.APPWIDGET_CONFIGURE" />
            </intent-filter>
        </activity>

        <activity
            android:name=".widgets.config.MediumWidgetConfigActivity"
            android:exported="true"
            android:label="@string/app_name">
            <intent-filter>
                <action android:name="android.appwidget.action.APPWIDGET_CONFIGURE" />
            </intent-filter>
        </activity>

        <activity
            android:name=".widgets.config.LargeWidgetConfigActivity"
            android:exported="true"
            android:label="@string/app_name">
            <intent-filter>
                <action android:name="android.appwidget.action.APPWIDGET_CONFIGURE" />
            </intent-filter>
        </activity>

        <!-- Small Widget (1x1) Receiver -->
        <receiver
            android:name=".widgets.glance.SmallWidgetReceiver"
            android:exported="true"
            android:label="@string/app_name">
            <intent-filter>
                <action android:name="android.appwidget.action.APPWIDGET_UPDATE" />
            </intent-filter>
            <meta-data
                android:name="android.appwidget.provider"
                android:resource="@xml/widget_small_info" />
        </receiver>

        <!-- Medium Widget (1x2) Receiver -->
        <receiver
            android:name=".widgets.glance.MediumWidgetReceiver"
            android:exported="true"
            android:label="@string/app_name">
            <intent-filter>
                <action android:name="android.appwidget.action.APPWIDGET_UPDATE" />
            </intent-filter>
            <meta-data
                android:name="android.appwidget.provider"
                android:resource="@xml/widget_medium_info" />
        </receiver>

        <!-- Large Widget (2x2) Receiver -->
        <receiver
            android:name=".widgets.glance.LargeWidgetReceiver"
            android:exported="true"
            android:label="@string/app_name">
            <intent-filter>
                <action android:name="android.appwidget.action.APPWIDGET_UPDATE" />
            </intent-filter>
            <meta-data
                android:name="android.appwidget.provider"
                android:resource="@xml/widget_large_info" />
        </receiver>

        <!-- Widget update broadcast receiver -->
        <receiver
            android:name=".widgets.receiver.WidgetUpdateBroadcastReceiver"
            android:exported="false"
            android:permission="com.gregor.lauritz.healthdashboard.WIDGET_SYNC_PERMISSION">
            <intent-filter>
                <action android:name="com.gregor.lauritz.healthdashboard.SYNC_COMPLETE" />
            </intent-filter>
        </receiver>

        <!-- Widget deletion broadcast receiver -->
        <receiver
            android:name=".widgets.receiver.WidgetDeletionReceiver"
            android:exported="false">
            <intent-filter>
                <action android:name="android.appwidget.action.APPWIDGET_DELETED" />
            </intent-filter>
        </receiver>

        <provider
            android:name="androidx.startup.InitializationProvider"
            android:authorities="${applicationId}.androidx-startup"
            android:exported="false"
            tools:node="merge">
            <meta-data
                android:name="androidx.work.WorkManagerInitializer"
                android:value="androidx.startup"
                tools:node="remove" />
        </provider>

        <activity-alias
            android:name="ViewPermissionUsageActivity"
            android:exported="true"
            android:permission="android.permission.START_VIEW_PERMISSION_USAGE"
            android:targetActivity=".ui.onboarding.PrivacyRationaleActivity">
            <intent-filter>
                <action android:name="android.intent.action.VIEW_PERMISSION_USAGE" />
                <category android:name="android.intent.category.HEALTH_PERMISSIONS" />
            </intent-filter>
        </activity-alias>
    </application>

</manifest>
