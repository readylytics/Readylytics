<?xml version="1.0" encoding="utf-8"?><!--
   Health data is sensitive — exclude from cloud backup and device-to-device transfer on Android 12+.
   See https://developer.android.com/about/versions/12/backup-restore#xml-changes
-->
<data-extraction-rules>
    <cloud-backup>
        <!-- Health data (Room DB, DataStore prefs, backup files) must not be uploaded to cloud. -->
        <exclude domain="root" path="." />
    </cloud-backup>
    <device-transfer>
        <!-- Encrypted keys and backups are device-specific; do not transfer to new devices. -->
        <exclude domain="root" path="." />
    </device-transfer>
</data-extraction-rules>