    <string name="tooltip_ras">Your 7-day rolling Readylytics Activity Score (RAS).\nBased on how often and how
        hard you challenge your heart.\n\n• 100+: Optimal\n• 75-99: Neutral\n• 50-74: Warning\n•
        &lt; 50: Poor</string>
    <string name="tooltip_readiness">Preparation for stress based on recent load &amp;
        recovery.\n\n• 85–100: Peak\n• 60–84: Maintain\n• 30–59: Caution\n• &lt; 30: High Fatigue</string>

    <string name="tooltip_sleep_score">Total quality of rest based on duration and cycles.\n\n•
        80–100: Optimal\n• 60–79: Fair\n• &lt; 60: Poor</string>

    <string name="tooltip_circadian_score">Measures how regular your sleep schedule is.\n\nHigh
        consistency stabilizes your internal clock, improving deep sleep and energy levels.\n\n• ≥
        80%%: Optimal\n• 60–79%%: Neutral\n• 40–59%%: Warning\n• &lt; 40%%: Poor\n\nConsistency
        Window: ±%1$d min grace period before score drops.</string>

    <string name="tooltip_sleep_rhr">Average heart rate during sleep.\nTarget: lower or equal to
        your 30-day rolling average. (Lower = Recovered)</string>
    <string name="tooltip_sleep_rhr_baseline">\n\nBaseline: %1$d bpm %2$s (%3$d bpm)</string>
    <string name="tooltip_sleep_rhr_no_baseline">\n\nNot enough data to calculate baseline.</string>

    <string name="tooltip_sleep_hrv">Variation between heartbeats in milliseconds.\nTarget: Within
        or above your 30-day rolling average. (Higher = Recovered)</string>
    <string name="tooltip_sleep_hrv_baseline">\n\nBaseline: %1$d ms %2$s (%3$d ms)</string>
    <string name="tooltip_sleep_hrv_baseline_no_today">\n\nBaseline: %1$d ms (today\'s HRV not yet
        available)</string>
    <string name="tooltip_sleep_hrv_no_baseline">\n\nNot enough data to calculate baseline.</string>
    <string name="tooltip_sleep_hrv_diagnostics">\n\nDiagnostics:\n• Z-score: %1$s\n• σ (ln-scale):
        %2$s</string>

    <string name="tooltip_sleep_duration">Total time asleep last night.\n\nGoal: %1$s</string>

    <string name="tooltip_resting_hr_baseline">Resting heart rate calculated as the low-percentile
        of the entire sleep period.\n\nBaseline: %1$d bpm %2$s (%3$d bpm)</string>
    <string name="tooltip_resting_hr_no_baseline">Resting heart rate calculated as the
        low-percentile of the entire sleep period.\n\nNot enough data to calculate baseline.</string>

    <string name="tooltip_strain_ratio">The ACWR (Acute:Chronic Workload Ratio). Compares recent
        training load to your baseline.\n\n• 0.8–1.3: In your normal range — sweet spot\n• 1.3–1.5:
        Load increasing; linear decay begins\n• 1.5–2.0: Overtraining; high injury risk\n• &gt;2.0:
        Severe overtraining; recovery needed\n• 0.5–0.8: Under-training\n• &lt;0.5: Severe
        under-training</string>

    
